{
  "name": "autoviralvid",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:agent\" --names ui,agent --prefix-colors blue,green --kill-others",
    "dev:debug": "LOG_LEVEL=debug npm run dev",
    "dev:agent": "cd agent && uv run main.py",
    "dev:agent:render": "cd agent && uv run uvicorn main:app --host 0.0.0.0 --port 8124",
    "predev:ui": "node scripts/cleanup-next-dev-lock.mjs",
    "dev:ui": "next dev --turbopack",
    "prisma:generate:safe": "node scripts/prisma-generate-safe.mjs",
    "prebuild": "npm run prisma:generate:safe",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:encoding-hygiene": "python scripts/check_encoding_hygiene.py",
    "test:integration": "cross-env RUN_INTEGRATION_TESTS=1 vitest run src/lib/render/render-api.test.ts src/lib/render/remotion-full-render.test.ts src/lib/render/remotion-integration.test.ts src/lib/render/remotion-perf.test.ts",
    "test:integration:paypal": "cross-env RUN_INTEGRATION_TESTS=1 RUN_PAYPAL_SANDBOX_E2E=1 vitest run src/integration/paypal-sandbox-billing.test.ts",
    "test:deployed": "cross-env RUN_DEPLOYED_INTEGRATION_TESTS=1 vitest run src/integration/deployed-environment.test.ts",
    "test:ui:openclaw": "python scripts/run_ui_openclaw_e2e.py",
    "test:ui:product-ad": "cross-env UI_E2E_SCENARIO=product-ad python scripts/run_ui_openclaw_e2e.py",
    "test:ui:brand-story-video": "cross-env UI_E2E_SCENARIO=brand-story-video python scripts/run_ui_openclaw_e2e.py",
    "test:ui:travel-vlog-media": "cross-env UI_E2E_SCENARIO=travel-vlog-media python scripts/run_ui_openclaw_e2e.py",
    "test:ui:knowledge": "cross-env UI_E2E_SCENARIO=knowledge-edu python scripts/run_ui_openclaw_e2e.py",
    "test:ui:knowledge-edu": "cross-env UI_E2E_SCENARIO=knowledge-edu python scripts/run_ui_openclaw_e2e.py",
    "test:ui:ppt-v7": "python scripts/run_ui_ppt_v7_e2e.py",
    "test:ui:ppt-v7:real": "python scripts/run_ui_ppt_v7_real_e2e.py",
    "test:ui:all": "cross-env UI_E2E_SCENARIO=all python scripts/run_ui_openclaw_e2e.py",
    "billing:reconcile": "tsx scripts/billing/reconcile.ts",
    "deploy:prod:verify": "npx tsc --noEmit && npx vitest run src/lib/billing/plan-catalog.test.ts src/lib/billing/charge-policy.test.ts src/lib/billing/stripe.test.ts src/lib/billing/webhook-events.test.ts src/app/api/billing/checkout/stripe/route.test.ts src/app/api/billing/checkout/paypal/route.test.ts src/app/api/billing/webhook/stripe/route.test.ts src/app/api/billing/webhook/paypal/route.test.ts src/app/api/billing/plans/route.test.ts src/app/api/internal/billing/reconcile/route.test.ts src/app/api/ppt/[...path]/route.test.ts src/app/api/projects/[...path]/route.test.ts",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "install:agent": "cd agent && uv sync",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@google/genai": "^1.44.0",
    "@marp-team/marp-core": "^4.3.0",
    "@prisma/client": "6.19.2",
    "@remotion/bundler": "^4.0.438",
    "@remotion/media-utils": "^4.0.434",
    "@remotion/player": "^4.0.434",
    "@remotion/renderer": "^4.0.438",
    "@remotion/transitions": "^4.0.434",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "idb": "^8.0.0",
    "jsonrepair": "^3.12.0",
    "lucide-react": "^0.562.0",
    "mathml2omml": "^0.5.0",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-icons": "^5.5.0",
    "remotion": "^4.0.434",
    "sharp": "^0.34.5",
    "shiki": "^3.13.0",
    "tailwind-merge": "^3.4.0",
    "temml": "^0.11.0",
    "uuid": "^13.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.0.18",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "prisma": "6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
